alias c='clear'
alias cclear='cd && clear'
alias codex='codex --dangerously-bypass-approvals-and-sandbox'
alias convert300='convert -density 300'
alias cp='cp --interactive'
alias df='df --human-readable --print-type'
alias du='du --human-readable --max-depth=1'
alias l='ls -l --human-readable'
alias la='ls --all -l'
alias mkdir='mkdir --parents'
alias mv='mv --interactive'
alias py='jupyter console'
alias rm='rm --interactive=once'
alias vi='nvim'

# use kitten ssh for clipboard/graphics forwarding when available (kitty terminal)
command -v kitten &>/dev/null && alias ssh='kitten ssh'
