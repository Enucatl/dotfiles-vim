[advice]
pushNonFastForward = false
commitBeforeMerge = false
implicitIdentity = false

[alias]
aa = add --all
amend = commit --amend
b = branch
bb = !better-git-branch.sh
ci = commit
co = checkout
diffwords = diff --color-words
export = "!f() { name=${PWD##*/}-$(git describe --always --abbrev=4 $1); git archive --prefix=$name -o $name.tar.gz $1; }; f"
graph = log --all --graph --decorate --oneline
ignore = "!gi() { for template in \"$@\"; do echo \"# Downloading .gitignore for $template...\"; curl -fsL \"https://raw.githubusercontent.com/github/gitignore/main/$template.gitignore\"; done; }; gi"
lg = log --color --graph --pretty=format:'%Cred%h %G?%Creset  %C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit
ours = "!f() { git checkout --ours $@ && git add $@; }; f"
pullupstream = !"git fetch origin --verbose; git fetch upstream --verbose; git merge --strategy-option theirs upstream/master"
s = status --short --branch
theirs = "!f() { git checkout --theirs $@ && git add $@; }; f"
unstage = reset HEAD

[branch]
sort = -committerdate

[color]
ui = auto
interactive = auto

[column]
ui = auto

[commit]
gpgSign = true
verbose = true

[core]
editor = vim --nofork
excludesfile = ~/.gitignore
pager = diff-so-fancy | less --tabs=4 -RF
whitespace = trailing-space,space-before-tab,space-in-empty-line

[difftool "diffpdf"]
cmd = diffpdf \"$LOCAL\" \"$REMOTE\"

[gpg]
format = ssh

[gpg "ssh"]
allowedSignersFile = ~/.ssh/allowed_ssh_signers

[help]
autocorrect = prompt

[init]
defaultBranch = main

[interactive]
diffFilter = diff-so-fancy --patch

[maintenance]
auto = true
strategy = incremental

[merge]
ff = always

[pull]
ff = only
rebase = true

[push]
autoSetupRemote = true
default = tracking

[rerere]
enabled = true
autoUpdate = true

[status]
branch = true

[submodule]
recurse = true

[tag]
forceSignAnnotated = true
gpgsign = true
sort = -version:refname

